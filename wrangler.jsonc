{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cetu-lms-api",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-12",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "env": {
    "staging": {
      "name": "cetu-lms-api-staging",
      "vars": {
        "NODE_ENV": "production",
        "PORT": "3000",
        "APP_BASE_URL": "https://cetu-lms-api-staging.cetu.workers.dev",
        "MONGO_DB_NAME": "LMS",
        "MONGO_COLLECTION_PREFIX": "staging_",
        "KEYCLOAK_AUDIENCE": "cetu-lms-api",
        "LTI_ISSUER": "https://cetu-lms-api-staging.cetu.workers.dev",
        "CORS_ORIGINS": "https://cetu-lms-web-staging.pages.dev,https://lms-staging.cetu.online",
        "LTI_TOOLS_JSON": "[{\"clientId\":\"pact-tool\",\"name\":\"PACT\",\"deploymentIds\":[\"pact-course-deployment\"],\"redirectUris\":[\"https://cetu-pact-api-staging.cetu.workers.dev/api/v1/lti/launch\"],\"deepLinkRedirectUris\":[\"https://cetu-pact-api-staging.cetu.workers.dev/api/v1/lti/deep-link\"],\"targetLinkUri\":\"https://cetu-pact-api-staging.cetu.workers.dev/launch\",\"publicJwks\":{\"keys\":[{\"kty\":\"RSA\",\"n\":\"75fmvoJJZB5SG0exYvnMVsEGvHV9QqfjpuUcINWoJx1g5dgImwGMzoN85il5OPuz8dG9Yoi8NMj_ddkyoMDqGUNpJCPPshS7wlgtilZcNdtRS1acmriQPiJjWRAQiyNblMogsaywuVPZsN66GCGv3PR9XDpjm8_1zidMWa0mYN2fTu3Aq0aiWk7o4qZPVilKm0RNs30_Fw_4hYe3AFeVG78_aPoxCA-EuRRcqKCqwo8Uue6Iag2iKCj1jWSBDDhDOrJKzOQiPNxzMCR_yGD6baGYTzu803amOcUlyPP_NnSqyBjxdo1mS9uFgpecv4EC5cPrWnzMk0ffytQCfT07kQ\",\"e\":\"AQAB\",\"kid\":\"pact-tool-key\",\"alg\":\"RS256\",\"use\":\"sig\"}]},\"scopes\":[\"https://purl.imsglobal.org/spec/lti-ags/scope/lineitem\",\"https://purl.imsglobal.org/spec/lti-ags/scope/lineitem.readonly\",\"https://purl.imsglobal.org/spec/lti-ags/scope/result.readonly\",\"https://purl.imsglobal.org/spec/lti-ags/scope/score\"]}]"
      }
    },
    "production": {
      "name": "cetu-lms-api",
      "vars": {
        "NODE_ENV": "production",
        "PORT": "3000",
        "APP_BASE_URL": "https://lms-api.cetu.online",
        "MONGO_DB_NAME": "LMS",
        "MONGO_COLLECTION_PREFIX": "",
        "KEYCLOAK_AUDIENCE": "cetu-lms-api",
        "LTI_ISSUER": "https://lms-api.cetu.online",
        "CORS_ORIGINS": "https://lms.cetu.online",
        "LTI_TOOLS_JSON": "[{\"clientId\":\"pact-tool\",\"name\":\"PACT\",\"deploymentIds\":[\"pact-course-deployment\"],\"redirectUris\":[\"https://pact2-api.cetu.online/api/v1/lti/launch\"],\"deepLinkRedirectUris\":[\"https://pact2-api.cetu.online/api/v1/lti/deep-link\"],\"targetLinkUri\":\"https://pact2-api.cetu.online/launch\",\"publicJwks\":{\"keys\":[{\"kty\":\"RSA\",\"n\":\"75fmvoJJZB5SG0exYvnMVsEGvHV9QqfjpuUcINWoJx1g5dgImwGMzoN85il5OPuz8dG9Yoi8NMj_ddkyoMDqGUNpJCPPshS7wlgtilZcNdtRS1acmriQPiJjWRAQiyNblMogsaywuVPZsN66GCGv3PR9XDpjm8_1zidMWa0mYN2fTu3Aq0aiWk7o4qZPVilKm0RNs30_Fw_4hYe3AFeVG78_aPoxCA-EuRRcqKCqwo8Uue6Iag2iKCj1jWSBDDhDOrJKzOQiPNxzMCR_yGD6baGYTzu803amOcUlyPP_NnSqyBjxdo1mS9uFgpecv4EC5cPrWnzMk0ffytQCfT07kQ\",\"e\":\"AQAB\",\"kid\":\"pact-tool-key\",\"alg\":\"RS256\",\"use\":\"sig\"}]},\"scopes\":[\"https://purl.imsglobal.org/spec/lti-ags/scope/lineitem\",\"https://purl.imsglobal.org/spec/lti-ags/scope/lineitem.readonly\",\"https://purl.imsglobal.org/spec/lti-ags/scope/result.readonly\",\"https://purl.imsglobal.org/spec/lti-ags/scope/score\"]}]"
      }
    }
  }
}
