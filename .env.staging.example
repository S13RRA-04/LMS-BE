NODE_ENV=production
PORT=4000
APP_BASE_URL=https://lms-api-staging.example.com
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=CETU
MONGO_COLLECTION_PREFIX=staging_
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/cetu
KEYCLOAK_AUDIENCE=cetu-lms-api
KEYCLOAK_JWKS_URI=https://keycloak.example.com/realms/cetu/protocol/openid-connect/certs
LTI_ISSUER=https://lms-api-staging.example.com
LTI_PLATFORM_KID=staging-key-id
LTI_PLATFORM_PRIVATE_KEY_PEM=replace-with-staging-private-key
LTI_TOOLS_JSON=[]
CORS_ORIGINS=https://cetu-lms-web-staging.pages.dev
