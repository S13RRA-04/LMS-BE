NODE_ENV=production
PORT=4000
APP_BASE_URL=https://lms-api-staging.example.com
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
# LMS owns only LMS/CETU Mongo databases and LMS/LTI collections.
# Do not point this at the PACT Mongo database or the Keycloak PostgreSQL database.
MONGO_DB_NAME=LMS
MONGO_COLLECTION_PREFIX=staging_
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/cetu
KEYCLOAK_AUDIENCE=cetu-lms-api
KEYCLOAK_JWKS_URI=https://keycloak.example.com/realms/cetu/protocol/openid-connect/certs
EMAIL_PROVIDER=noop
# Set EMAIL_PROVIDER=resend and provide the next values to send access request notifications.
EMAIL_FROM=no-reply@example.com
ACCESS_REQUEST_ADMIN_EMAIL=admin@example.com
RESEND_API_KEY=replace-with-resend-api-key
LTI_ISSUER=https://lms-api-staging.example.com
LTI_PLATFORM_KID=staging-key-id
LTI_PLATFORM_PRIVATE_KEY_PEM=replace-with-staging-private-key
LTI_TOOLS_JSON=[{"clientId":"pact-tool","name":"PACT","deploymentIds":["pact-course-deployment"],"redirectUris":["https://cetu-pact-api-staging.cetu.workers.dev/api/v1/lti/launch"],"deepLinkRedirectUris":["https://cetu-pact-api-staging.cetu.workers.dev/api/v1/lti/deep-link"],"targetLinkUri":"https://cetu-pact-api-staging.cetu.workers.dev/launch","publicJwks":{"keys":[]},"scopes":[]}]
CORS_ORIGINS=https://cetu-lms-web-staging.pages.dev
