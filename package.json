{
  "name": "cetu-lms-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "db:ensure": "tsx src/db/ensureMongo.ts",
    "db:seed": "tsx src/db/seedLms.ts",
    "cloudflare:whoami": "wrangler whoami",
    "cloudflare:secrets:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/set-cloudflare-worker-secrets.ps1",
    "staging:pact-tool": "powershell -ExecutionPolicy Bypass -File ./scripts/configure-pact-tool-staging.ps1",
    "deploy:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-staging-node.ps1",
    "deploy:worker:legacy": "wrangler deploy",
    "local:infra:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-infra.ps1",
    "local:tunnel:lms-api": "powershell -ExecutionPolicy Bypass -File ./scripts/start-lms-api-tunnel.ps1",
    "local:keycloak:bootstrap": "node ./scripts/bootstrap-keycloak.mjs",
    "local:data:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/reset-local-data.ps1",
    "local:infra:teardown": "powershell -ExecutionPolicy Bypass -File ./scripts/teardown-local-infra.ps1",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jose": "^5.6.3",
    "mongodb": "^6.8.0",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/supertest": "^7.2.0",
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1"
  }
}
